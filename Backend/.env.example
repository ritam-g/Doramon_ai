# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173,http://localhost:5174
APP_URL=http://localhost:5000
CLIENT_BUILD_DIR=Frontend/dist

# Cookies
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret

# AI providers
GOOGLE_API_KEY=
MISTRAL_API_KEY=
TAVILY_API_KEY=

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRETKEY=
GOOGLE_REFRESH_TOKEN=

# Email
GOOGLE_EMAIL_USER=
GOOGLE_EMAIL_PASS=

# ImageKit
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_END_URL=https://ik.imagekit.io/<your-endpoint>

# Vector DB
VECTOR_API_KEY=
VECTOR_INDEX_NAME=
